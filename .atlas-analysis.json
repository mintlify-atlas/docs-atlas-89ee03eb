  "keyFeatures": [
    "Direct Google Flights API access (no web scraping)",
    "MCP server for AI assistant integration",
    "Rich CLI interface with Typer",
    "Flight search with advanced filtering (cabin class, stops, airlines, time windows)",
    "Date range search for finding cheapest travel dates",
    "Built-in rate limiting and retry logic",
    "Pydantic models for type safety",
    "Support for one-way and round-trip flights"
